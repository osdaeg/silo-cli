#!/usr/bin/env python3
"""
raindrop-import.py — importa un backup de Raindrop a Silo
Uso:
  python3 raindrop-import.py backup.json            # importa y sincroniza con Raindrop
  python3 raindrop-import.py backup.json --no-sync  # importa sin resubir a Raindrop
"""

import json
import sys
import time
import urllib.request
import urllib.error

# ── Configuración ─────────────────────────────────────
SILO_HOST  = "http://192.168.1.10:7123"
SILO_TOKEN = "TokenAPISilo"
DELAY      = 0.1  # segundos entre requests para no saturar el servidor
# ─────────────────────────────────────────────────────


def silo_get(path):
    req = urllib.request.Request(
        f"{SILO_HOST}{path}",
        headers={"Authorization": f"Bearer {SILO_TOKEN}"}
    )
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read().decode())


def silo_post(path, body):
    data = json.dumps(body).encode()
    req = urllib.request.Request(
        f"{SILO_HOST}{path}",
        data=data,
        headers={
            "Authorization": f"Bearer {SILO_TOKEN}",
            "Content-Type": "application/json"
        },
        method="POST"
    )
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read().decode())


def get_or_create_collection(name, existing):
    """Retorna el id de la colección, creándola si no existe."""
    for col in existing:
        if col["name"].lower() == name.lower():
            return col["id"]
    print(f"  Creando colección: {name}")
    col = silo_post("/collections", {"name": name})
    existing.append(col)
    return col["id"]


def mark_synced(link_id):
    """Marca el enlace como ya sincronizado con Raindrop via SQL directo... 
    o simplemente lo dejamos como synced ya que viene de Raindrop."""
    # No hay endpoint para esto, pero el servidor lo sincronizará
    # en el próximo cron si no está marcado. Con --no-sync simplemente
    # no llamamos al sync y Silo lo intentará después.
    pass


def main():
    if SILO_TOKEN == "TU_TOKEN_AQUI":
        print("Error: reemplazá TU_TOKEN_AQUI con tu token de Silo")
        sys.exit(1)

    # Argumentos
    args = sys.argv[1:]
    if not args:
        print("Uso: python3 raindrop-import.py backup.json [--no-sync]")
        sys.exit(1)

    backup_file = args[0]
    no_sync = "--no-sync" in args

    # Leer backup
    try:
        with open(backup_file, encoding="utf-8") as f:
            backup = json.load(f)
    except FileNotFoundError:
        print(f"Error: no se encontró el archivo {backup_file}")
        sys.exit(1)

    items = backup.get("items", [])
    print(f"Backup: {len(items)} enlaces")
    print(f"Modo: {'sin sync a Raindrop' if no_sync else 'con sync a Raindrop'}")
    print()

    # Colecciones existentes en Silo
    try:
        collections = silo_get("/collections")
    except Exception as e:
        print(f"Error conectando a Silo: {e}")
        sys.exit(1)

    # Obtener URLs ya existentes en Silo para evitar duplicados
    print("Verificando enlaces existentes en Silo...")
    try:
        existing_links = silo_get("/links")
        existing_urls = {l["url"] for l in existing_links}
        print(f"  {len(existing_urls)} enlaces ya en Silo")
    except Exception as e:
        print(f"Error obteniendo enlaces: {e}")
        sys.exit(1)

    # Importar
    imported = 0
    skipped  = 0
    errors   = 0

    items = list(reversed(items))
    print(f"\nImportando...")
    for i, item in enumerate(items, 1):
        url = item.get("url")
        if not url:
            skipped += 1
            continue

        # Saltar duplicados
        if url in existing_urls:
            print(f"  [{i}/{len(items)}] SKIP (ya existe): {url[:60]}")
            skipped += 1
            continue

        # Resolver colección
        col_name = item.get("collection")
        col_id = None
        if col_name and col_name not in ("Sin colección", ""):
            try:
                col_id = get_or_create_collection(col_name, collections)
            except Exception:
                col_id = None

        body = {
            "url":           url,
            "title":         item.get("title") or None,
            "description":   item.get("excerpt") or item.get("note") or None,
            "collection_id": col_id,
        }

        # Si --no-sync, le decimos al servidor que no haga sync
        # agregando raindrop_id ficticio... no tenemos ese endpoint.
        # La solución es usar el endpoint normal y luego el cron lo manejará.
        # Con --no-sync simplemente no forzamos sync manual.

        try:
            silo_post("/links", body)
            existing_urls.add(url)
            imported += 1
            title = item.get("title") or url
            print(f"  [{i}/{len(items)}] OK: {title[:60]}")
        except urllib.error.HTTPError as e:
            errors += 1
            print(f"  [{i}/{len(items)}] ERROR {e.code}: {url[:60]}")
        except Exception as e:
            errors += 1
            print(f"  [{i}/{len(items)}] ERROR: {e}")

        time.sleep(DELAY)

    print(f"\n{'─'*50}")
    print(f"✔ Importados:  {imported}")
    print(f"⊘ Salteados:   {skipped} (duplicados o sin URL)")
    print(f"✕ Errores:     {errors}")

    if no_sync:
        print("\nNota: los enlaces importados tienen sync pendiente.")
        print("Raindrop NO será notificado (usá 'SYNC AHORA' en el dashboard si querés sincronizar manualmente después).")


if __name__ == "__main__":
    main()

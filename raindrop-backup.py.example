#!/usr/bin/env python3
"""
raindrop-backup.py — descarga todos los enlaces de Raindrop y los guarda en JSON
Uso: python3 raindrop-backup.py
"""

import json
import sys
import urllib.request
import urllib.error
from datetime import datetime

# ── Configuración ─────────────────────────────────────
RAINDROP_TOKEN = "TuTokenDeRaindrop"
OUTPUT_FILE = f"raindrop-backup-{datetime.now().strftime('%Y%m%d-%H%M%S')}.json"
PAGE_SIZE = 50  # máximo que acepta la API
# ─────────────────────────────────────────────────────


def raindrop_get(url):
    req = urllib.request.Request(
        url,
        headers={"Authorization": f"Bearer {RAINDROP_TOKEN}"}
    )
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.loads(resp.read().decode())


def get_collections():
    print("Obteniendo colecciones...")
    data = raindrop_get("https://api.raindrop.io/rest/v1/collections")
    cols = {str(c["_id"]): c["title"] for c in data.get("items", [])}
    cols["-1"] = "Sin colección"
    cols["0"]  = "Sin colección"
    return cols


def get_all_raindrops():
    all_items = []
    page = 0
    while True:
        url = f"https://api.raindrop.io/rest/v1/raindrops/0?perpage={PAGE_SIZE}&page={page}"
        print(f"  Página {page + 1}...", end=" ", flush=True)
        data = raindrop_get(url)
        items = data.get("items", [])
        print(f"{len(items)} enlaces")
        if not items:
            break
        all_items.extend(items)
        if len(items) < PAGE_SIZE:
            break
        page += 1
    return all_items


def main():
    if RAINDROP_TOKEN == "TU_TOKEN_AQUI":
        print("Error: reemplazá TU_TOKEN_AQUI con tu token de Raindrop")
        sys.exit(1)

    try:
        collections = get_collections()
        print(f"Colecciones encontradas: {len(collections)}")

        print("Descargando enlaces...")
        items = get_all_raindrops()
        print(f"Total: {len(items)} enlaces")

        # Limpiar y estructurar
        backup = []
        for item in items:
            col_id = str(item.get("collection", {}).get("$id", "-1"))
            backup.append({
                "id":          item.get("_id"),
                "url":         item.get("link"),
                "title":       item.get("title"),
                "excerpt":     item.get("excerpt"),
                "note":        item.get("note"),
                "tags":        item.get("tags", []),
                "collection":  collections.get(col_id, col_id),
                "created":     item.get("created"),
                "lastUpdate":  item.get("lastUpdate"),
                "domain":      item.get("domain"),
                "type":        item.get("type"),
            })

        output = {
            "exported_at": datetime.now().isoformat(),
            "total":       len(backup),
            "items":       backup,
        }

        with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
            json.dump(output, f, ensure_ascii=False, indent=2)

        print(f"\n✔ Backup guardado en: {OUTPUT_FILE}")

    except urllib.error.HTTPError as e:
        print(f"\n✕ Error HTTP {e.code}: {e.reason}")
        if e.code == 401:
            print("  Token inválido o expirado")
        sys.exit(1)
    except Exception as e:
        print(f"\n✕ Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
